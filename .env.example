# ========================================================================
# Grace HP 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、各値を設定してください。
#   cp .env.example .env.local
# .env.local は .gitignore で除外されます（絶対にコミットしないこと）。
# 値はプレースホルダです。実値は Vercel の環境変数 / GitHub Secrets 側にも設定します。
# ========================================================================

# ---- Notion（コンテンツ管理）----
NOTION_TOKEN=
NOTION_DB_PRODUCTS=
NOTION_DB_JOURNAL=
NOTION_DB_NEWS=
NOTION_DB_CONTACTS=
NOTION_DB_SUBSCRIBERS=

# ---- メール送信（Resend）----
RESEND_API_KEY=
CONTACT_EMAIL_FROM=
CONTACT_EMAIL_TO=

# ---- ISR revalidate / アクセス解析 ----
REVALIDATE_SECRET=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SITE_URL=

# ---- reCAPTCHA v3（メール登録フォームのスパム対策）----
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ---- Square（メール登録 → 顧客作成）----
SQUARE_ACCESS_TOKEN=
SQUARE_OPEN_NOTICE_GROUP_ID=
